---
import BaseLayout from "../layouts/BaseLayout.astro";
import Counter from "../components/Counter";
---

<BaseLayout title="Astro Boilerplate">
  <main class="mx-auto max-w-2xl px-6 py-20 space-y-12">
    <section class="space-y-3">
      <h1 class="text-4xl font-bold tracking-tight text-foreground">
        Project shell
      </h1>
      <p class="text-muted-foreground">
        Astro 6 + Tailwind v4 + React 19 + MDX + Cloudflare Workers. Pre-wired with the full shadcn token system, a working React island, and an MDX blog scaffold. Fork and build.
      </p>
    </section>

    <section class="space-y-2">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Design tokens</h2>
      <div class="grid grid-cols-4 gap-2">
        <div class="aspect-square rounded-md bg-primary" title="primary"></div>
        <div class="aspect-square rounded-md bg-success" title="success"></div>
        <div class="aspect-square rounded-md bg-warning" title="warning"></div>
        <div class="aspect-square rounded-md bg-destructive" title="destructive"></div>
      </div>
      <p class="text-sm text-muted-foreground">
        Edit <code class="rounded bg-muted px-1.5 py-0.5">src/styles/global.css</code> to rebrand. Run <code class="rounded bg-muted px-1.5 py-0.5">/brand-guidelines</code> for the token map.
      </p>
    </section>

    <section class="space-y-2">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">React island</h2>
      <Counter client:load initial={0} />
      <p class="text-sm text-muted-foreground">
        <code class="rounded bg-muted px-1.5 py-0.5">.tsx</code> in <code class="rounded bg-muted px-1.5 py-0.5">src/components/</code>, mounted with <code class="rounded bg-muted px-1.5 py-0.5">client:load</code>.
      </p>
    </section>

    <section class="space-y-2">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Blog</h2>
      <a href="/blog" class="inline-flex items-center rounded-md border border-border px-3 py-1.5 text-sm font-medium text-foreground hover:bg-accent transition-colors">
        Open blog →
      </a>
      <p class="text-sm text-muted-foreground">
        Content collection at <code class="rounded bg-muted px-1.5 py-0.5">src/content/blog/</code>. Drop in MDX files, they render at <code class="rounded bg-muted px-1.5 py-0.5">/blog/[slug]</code>.
      </p>
    </section>
  </main>
</BaseLayout>
