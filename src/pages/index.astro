---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Astro Boilerplate">
  <main class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-4xl font-bold tracking-tight">Astro Boilerplate</h1>
    <p class="mt-4 text-lg text-gray-600">
      Astro 6 + Tailwind CSS v4. Edit <code class="rounded bg-gray-100 px-1.5 py-0.5 text-sm font-mono">src/pages/index.astro</code> to get started.
    </p>
  </main>
</BaseLayout>
