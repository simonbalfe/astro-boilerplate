---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Astro Boilerplate">
  <main class="mx-auto max-w-3xl px-6 py-16 space-y-12">
    <section>
      <h1 class="text-5xl font-extrabold tracking-tight bg-gradient-to-r from-foreground via-foreground/80 to-foreground/60 bg-clip-text text-transparent">
        Astro Boilerplate
      </h1>
      <p class="mt-4 text-lg text-muted-foreground max-w-xl">
        Astro 6 + Tailwind CSS v4 + Cloudflare Workers. If the styles below render correctly, Tailwind is working.
      </p>
    </section>

    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="rounded-2xl bg-accent p-6 shadow-sm border border-border hover:shadow-md transition-shadow">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-accent-foreground">Spacing</h3>
        <p class="mt-2 text-muted-foreground text-sm leading-relaxed">Padding, margin, gap, and space-y all working.</p>
      </div>
      <div class="rounded-2xl bg-success/10 p-6 shadow-sm border border-success/20 hover:shadow-md transition-shadow">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-success">Colors</h3>
        <p class="mt-2 text-muted-foreground text-sm leading-relaxed">Background, text, and border colors rendering.</p>
      </div>
      <div class="rounded-2xl bg-warning/10 p-6 shadow-sm border border-warning/20 hover:shadow-md transition-shadow">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-warning">Typography</h3>
        <p class="mt-2 text-muted-foreground text-sm leading-relaxed">Font sizes, weights, tracking, and leading.</p>
      </div>
    </section>

    <section class="flex flex-wrap gap-3">
      <span class="inline-flex items-center rounded-full bg-info/10 px-3 py-1 text-xs font-medium text-info ring-1 ring-info/10">Badge</span>
      <span class="inline-flex items-center rounded-full bg-warning/10 px-3 py-1 text-xs font-medium text-warning ring-1 ring-warning/10">Alert</span>
      <span class="inline-flex items-center rounded-full bg-success/10 px-3 py-1 text-xs font-medium text-success ring-1 ring-success/10">Success</span>
      <span class="inline-flex items-center rounded-full bg-accent px-3 py-1 text-xs font-medium text-accent-foreground ring-1 ring-border">Info</span>
    </section>

    <section class="space-y-4">
      <button class="rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring active:scale-95 transition-all">
        Primary Button
      </button>
      <div class="flex items-center gap-4">
        <div class="h-12 w-12 rounded-full bg-gradient-to-br from-primary to-primary/60 shadow-lg"></div>
        <div class="h-12 w-12 rounded-lg bg-success shadow-lg rotate-12"></div>
        <div class="h-12 w-12 rounded-lg bg-warning shadow-lg -skew-x-6"></div>
        <div class="h-12 w-12 rounded-full bg-info shadow-lg ring-4 ring-info/10"></div>
      </div>
    </section>

    <section class="rounded-xl border border-border overflow-hidden">
      <div class="bg-muted px-4 py-3 border-b border-border">
        <h3 class="text-sm font-semibold text-foreground">Responsive Table</h3>
      </div>
      <div class="divide-y divide-border">
        <div class="flex justify-between px-4 py-3 text-sm">
          <span class="font-medium text-foreground">Flexbox</span>
          <span class="text-success font-mono text-xs bg-success/10 px-2 py-0.5 rounded">working</span>
        </div>
        <div class="flex justify-between px-4 py-3 text-sm">
          <span class="font-medium text-foreground">Grid</span>
          <span class="text-success font-mono text-xs bg-success/10 px-2 py-0.5 rounded">working</span>
        </div>
        <div class="flex justify-between px-4 py-3 text-sm">
          <span class="font-medium text-foreground">Transitions</span>
          <span class="text-success font-mono text-xs bg-success/10 px-2 py-0.5 rounded">working</span>
        </div>
        <div class="flex justify-between px-4 py-3 text-sm">
          <span class="font-medium text-foreground">Transforms</span>
          <span class="text-success font-mono text-xs bg-success/10 px-2 py-0.5 rounded">working</span>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
