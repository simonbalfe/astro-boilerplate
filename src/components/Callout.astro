---
interface Props {
  type?: "info" | "warning" | "success";
}

const { type = "info" } = Astro.props;

const styles = {
  info: "bg-info-50 border-info-600/20 text-info-600",
  warning: "bg-warning-50 border-warning-600/20 text-warning-600",
  success: "bg-success-50 border-success-600/20 text-success-600",
};
---

<div class={`rounded-lg border p-4 text-sm ${styles[type]}`}>
  <slot />
</div>
