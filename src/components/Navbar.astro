---
const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
];

const currentPath = Astro.url.pathname;
---

<nav class="border-b border-border bg-background/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="mx-auto max-w-2xl px-6 flex items-center justify-between h-14">
    <a href="/" class="text-sm font-bold tracking-tight text-foreground">Astro Boilerplate</a>
    <div class="flex items-center gap-6">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "text-sm transition-colors",
            currentPath === href || (href !== "/" && currentPath.startsWith(href))
              ? "text-foreground font-medium"
              : "text-muted-foreground hover:text-foreground",
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>
